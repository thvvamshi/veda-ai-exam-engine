PORT=5000

NODE_ENV=development

JWT_SECRET= your secret key

MONGO_URI= your mongo atlas url

# Note: Upstash Redis free tier has limited connections, so we can use it for testing, but for production, consider using a more robust Redis solution
REDIS_URL= your redis url (cloud)

# free models best in free tier, but you can test with others if needed
GROQ_API_KEY= your GROQ key 

GROQ_MODEL=llama-3.3-70b-versatile

# Note: OpenRouter's free tier has limited models, so we can try multiple if needed
# for perfect results, you might want to test with ""gpt-3.5-turbo"
OPENROUTER_API_KEY= your OpenRoute api key

OPENROUTER_MODEL=google/gemma-2-9b-it:free

# cloudinary credentials for image uploads

CLOUDINARY_CLOUD_NAME= your cloudinary name

CLOUDINARY_API_KEY= your cloudinary key

CLOUDINARY_API_SECRET= your cloudinary secret

